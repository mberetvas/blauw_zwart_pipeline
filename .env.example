# Copy to `.env` and adjust. Never commit `.env`.
#
# --- PostgreSQL (postgres service + host clients) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=fan_pipeline
# MCP Toolbox (googleapis/mcp-toolbox, --prebuilt=postgres). Keep in sync with POSTGRES_DB.
POSTGRES_DATABASE=fan_pipeline
# Host port published for psql/IDE (change if 5432 is already in use — FR-014)
POSTGRES_PORT=5432

# --- pgAdmin (browser UI) ---
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme
PGADMIN_PORT=5050

# --- Kafka (Compose producer + ingest use INTERNAL listener DNS) ---
# Topic is auto-created on first produce (FR-013); default partition count follows
# broker KAFKA_NUM_PARTITIONS in docker-compose.yml (e.g. 3).
KAFKA_BOOTSTRAP_SERVERS=broker:29092
KAFKA_TOPIC=fan_events
KAFKA_CONSUMER_GROUP=fan-ingest-local

# --- Pro League scraper pipeline (scheduler → Kafka → proleague-ingest → Postgres) ---
# Topic name for player stats messages; created by kafka-init-scraper on stack start.
SCRAPER_KAFKA_TOPIC=player_stats
# Consumer group for the proleague-ingest service (distinct from fan-ingest-local).
SCRAPER_KAFKA_CONSUMER_GROUP=scraper-ingest-local
# How often the scheduler runs (hours). Default 24 = once per day.
SCRAPER_INTERVAL_HOURS=24
# Set to "1" to run a scrape immediately on proleague-scheduler container start.
SCRAPER_RUN_ON_STARTUP=1
# Override the default Club Brugge squad URL (leave unset to use the built-in default).
# PROLEAGUE_SQUAD_URL=https://www.proleague.be/teams/club-brugge-kv-182/squad

# --- Ingest → Postgres (asyncpg) ---
# Use service hostname `postgres` from the ingest container; use `localhost` only from the host.
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/fan_pipeline

# --- Compose producer (fan_events stream inside Docker Compose) ---
# The producer mounts ./match_day.example.json and publishes merged v2 + v3 events continuously.
# With --calendar, the stream loops the season by default (see fan_events stream --help).
FAN_EVENTS_STREAM_SEED=42
FAN_EVENTS_STREAM_EMIT_WALL_CLOCK_MIN=0.1
FAN_EVENTS_STREAM_EMIT_WALL_CLOCK_MAX=0.5
# Optional: producer log level for fan_events.kafka (also LOGLEVEL). Compose producer also sets
# FAN_EVENTS_KAFKA_PROGRESS_INTERVAL in docker-compose.yml (overrides code default 256 if unset).
# FAN_EVENTS_LOG_LEVEL=DEBUG

# --- Optional host producer (fan_events stream from your machine) ---
# From the host machine, use the EXTERNAL listener:
#   FAN_EVENTS_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
#   FAN_EVENTS_KAFKA_TOPIC=fan_events
# (Uncomment and align KAFKA_TOPIC / FAN_EVENTS_KAFKA_TOPIC if you run an extra host producer.)

# --- dbt (dbt/profiles.yml reads these via env_var; copy profiles.yml.example → profiles.yml) ---
#
# Windows: if `dbt --version` prints "dbt-fusion", the `dbt` on your PATH is the Rust preview, not this
# project. Fusion's Postgres adapter can fail with "LoadLibraryExW failed" even when Docker Postgres is up.
# Fix: use the venv adapter — `uv sync --group dbt` then always `uv run dbt ...` (not bare `dbt`).
#
# Export/load this .env before `uv run dbt` (PowerShell: Get-Content .env | line-by-line, or direnv).
# DBT_PROFILES_DIR: directory containing profiles.yml (absolute path is reliable on Windows).
# Do not put # comments on the same line as values — some loaders include the comment in the path.
#
# Never set DBT_PROFILE to the path of profiles.yml (e.g. .../dbt/profiles.yml). DBT_PROFILE is the
# *profile name* inside that file (here: fan_sim_pipeline). Wrong value → "profile ... not found".
# Leave DBT_PROFILE unset (dbt uses dbt_project.yml `profile:`) or set DBT_PROFILE=fan_sim_pipeline.
DBT_PROFILES_DIR=./dbt
# Host connection when dbt runs on your machine (not inside Docker): localhost + published POSTGRES_PORT.
DBT_POSTGRES_HOST=localhost
DBT_POSTGRES_PORT=5432
# Schema for dbt models (keep raw ingest in public).
DBT_TARGET_SCHEMA=dbt_dev
# Compose dbt scheduler: first run starts immediately, then repeats on this interval.
DBT_RUN_INTERVAL_MINUTES=5
# Refresh the loyalty mart and any upstream models it depends on.
DBT_RUN_SELECTOR=+mart_fan_loyalty

# --- LLM Q&A API (llm-api service) ---
# Dev-only password for the read-only llm_reader role (provisioned by 002_llm_reader.sql).
# Change this in your copied .env file before sharing the stack or reusing it elsewhere.
LLM_READER_PASSWORD=change-this-dev-password
# Connection string for the read-only llm_reader role. Used inside Docker Compose:
# service hostname `postgres`. Keep the password aligned with LLM_READER_PASSWORD.
LLM_READER_DATABASE_URL=postgresql://llm_reader:change-this-dev-password@postgres:5432/fan_pipeline
# Ollama host URL. Default reaches the host machine from within Docker.
# Change to http://ollama:11434 if running Ollama as a Compose service instead.
OLLAMA_URL=http://host.docker.internal:11434
# Model tag — must be pulled on the Ollama host: `ollama pull gemma4:e2b`
OLLAMA_MODEL=gemma4:e2b
# Host port for the Flask LLM API (change if 8080 is in use).
LLM_API_PORT=8080

# LLM provider: "ollama" (local, default) or "openrouter" (hosted).
# The UI can override this per-request; this sets the server-side default.
LLM_PROVIDER=ollama

# OpenRouter (https://openrouter.ai/) — only required when LLM_PROVIDER=openrouter.
# The API key is server-side only and is never sent to or accepted from the browser.
# Get a key at https://openrouter.ai/keys and set it here.
OPENROUTER_API_KEY=
# Base URL — leave at the default unless you proxy the OpenRouter API.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default model used when the UI leaves the model field blank (OpenRouter model id).
OPENROUTER_MODEL=deepseek/deepseek-v3.2
# Optional comma-separated model ids for chat/settings datalist suggestions. If unset, the API uses its
# built-in defaults: deepseek/deepseek-v3.2, google/gemini-3.1-flash-lite-preview, minimax/minimax-m2.5, x-ai/grok-4.1-fast
# OPENROUTER_MODELS=deepseek/deepseek-v3.2,google/gemini-3.1-flash-lite-preview,minimax/minimax-m2.5,x-ai/grok-4.1-fast
# Optional JSON file for Club Settings persistence. Defaults to src/llm_api/llm_config.json when unset.
# Docker Compose sets LLM_CONFIG_PATH=/data/llm_config.json with a named volume.
# LLM_CONFIG_PATH=

# --- LLM schema context (Text-to-SQL): merged dbt YAML docs ---
# Priority: SCHEMA_FILES (comma-separated) > DBT_MODELS_DIR > SCHEMA_FILE (single path).
# Docker llm-api image sets DBT_MODELS_DIR to baked dbt_schema/ (staging, intermediate, marts).
# Local example: point at the repo (paths relative to cwd when you start the API):
# DBT_MODELS_DIR=./dbt/models
# Or explicit files:
# SCHEMA_FILES=./dbt/models/staging/fan_events_ingested/_schema.yaml,./dbt/models/intermediate/merch_purchase/_schema.yaml,./dbt/models/intermediate/retail_purchase/_schema.yaml,./dbt/models/intermediate/match_events/_schema.yaml,./dbt/models/marts/schema.yml
# Single-file fallback (default if unset: src/llm_api/schema.yml next to the package):
# SCHEMA_FILE=./dbt/models/marts/schema.yml
# Postgres schema name echoed in the LLM prompt (align with DBT_TARGET_SCHEMA / 002_llm_reader.sql).
# DBT_RELATION_SCHEMA=dbt_dev
# Optional cap on merged schema text size (0 = unlimited). SCHEMA_CONTEXT_OVERFLOW=error|truncate
# SCHEMA_CONTEXT_MAX_CHARS=120000
# SCHEMA_CONTEXT_OVERFLOW=error
