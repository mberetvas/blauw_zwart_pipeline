# Copy to `.env` and adjust. Never commit `.env`.
#
# --- PostgreSQL (postgres service + host clients) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=fan_pipeline
# Host port published for psql/IDE (change if 5432 is already in use — FR-014)
POSTGRES_PORT=5432

# --- pgAdmin (browser UI) ---
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme
PGADMIN_PORT=5050

# --- Kafka (ingest runs inside Compose: use INTERNAL listener DNS) ---
# Topic is auto-created on first produce (FR-013); default partition count follows
# broker KAFKA_NUM_PARTITIONS in docker-compose.yml (e.g. 3).
KAFKA_BOOTSTRAP_SERVERS=broker:29092
KAFKA_TOPIC=fan_events
KAFKA_CONSUMER_GROUP=fan-ingest-local

# --- Ingest → Postgres (asyncpg) ---
# Use service hostname `postgres` from the ingest container; use `localhost` only from the host.
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/fan_pipeline

# --- Host producer (fan_events stream — FR-015) ---
# From the host machine, use the EXTERNAL listener:
#   FAN_EVENTS_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
#   FAN_EVENTS_KAFKA_TOPIC=fan_events
# (Uncomment and align KAFKA_TOPIC / FAN_EVENTS_KAFKA_TOPIC.)
